{
  "name": "cmux-win",
  "version": "0.1.0",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test:e2e": "electron-vite build && npx playwright test",
    "bench": "vitest bench",
    "package": "electron-vite build && electron-builder",
    "build:mcp": "esbuild src/mcp/cmux-mcp-server.ts --bundle --platform=node --target=node18 --format=cjs --banner:js=\"#!/usr/bin/env node\" --outfile=resources/mcp/cmux-mcp-server.js && node -e \"const fs=require('fs'),os=require('os'),p=require('path');const d=p.join(os.homedir(),'.cmux-win','mcp');fs.mkdirSync(d,{recursive:true});fs.copyFileSync('resources/mcp/cmux-mcp-server.js',p.join(d,'cmux-mcp-server.js'));console.log('[build:mcp] deployed to ~/.cmux-win/mcp/')\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@grammyjs/auto-retry": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "electron": "^33.4.11",
    "electron-updater": "^6.8.3",
    "grammy": "^1.41.1",
    "i18next": "^25.10.1",
    "immer": "^11.1.4",
    "node-pty": "^1.1.0",
    "react": "18.3",
    "react-dom": "18.3",
    "react-i18next": "^16.5.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.7.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "5.4",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  }
}
